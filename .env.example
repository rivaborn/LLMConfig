# LLMConfig configuration. Copy to `.env` and edit. `.env` is gitignored — keep secrets here only.
# Every value below has a sane default in llmconfig/config.py; uncomment to override.

# --- the control app itself ---
LLMCONFIG_HOST=0.0.0.0
LLMCONFIG_PORT=11430                 # avoids 11434 (ollama) / 11436 (vllm) / 11437 (relay)
LLMCONFIG_API_KEY=                   # optional; if set, write ops (load/unload/pull/...) require X-API-Key

# --- Ollama (Windows-native) ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_SERVICE_NAME=ollama           # Windows service name (Get-/Start-/Restart-Service)

# --- vLLM (WSL2) ---
VLLM_RELAY_URL=http://127.0.0.1:11437   # socat relay; use 127.0.0.1, NOT localhost (IPv4 happy-eyeballs)
VLLM_SERVE_SCRIPT=/home/folar/vllm/serve.sh
VLLM_SYSTEMD_UNIT=vllm@                  # templated systemd-user unit; instance name = serve.sh alias

# --- WSL plumbing ---
WSL_DISTRO=Ubuntu-24.04
WSL_USER=folar

# --- GPU (primary lane = RTX 3090) ---
GPU_UUID=GPU-739bece9-8298-7993-f7dd-c8d86cb541f9   # the RTX 3090 (pin by UUID, never index)
VRAM_TOTAL_MB=24576
VRAM_FREE_BASELINE_MB=1500           # "VRAM is freed" / "GPU is maxed" threshold

# --- companion lane (RTX 3070 Ti) — optional 2nd GPU; off unless enabled ---
# Setup: deploy\install-companion.ps1 (2nd Ollama) + serve-companion.sh / a 2nd socat
# relay / vllm-companion@.service for companion vLLM. See deploy/README-deploy.md.
COMPANION_ENABLED=false
COMPANION_GPU_UUID=GPU-2caf7863-102e-31e5-be4d-5ec860addc78   # the RTX 3070 Ti (pin by UUID)
COMPANION_VRAM_TOTAL_MB=8192
COMPANION_VRAM_FREE_BASELINE_MB=600
COMPANION_OLLAMA_URL=http://127.0.0.1:11435       # 2nd Ollama instance
COMPANION_OLLAMA_SERVICE_NAME=OllamaCompanion
COMPANION_VLLM_RELAY_URL=http://127.0.0.1:11438   # 2nd socat relay → companion vLLM
COMPANION_VLLM_SERVE_SCRIPT=/home/folar/vllm/serve-companion.sh
COMPANION_VLLM_SYSTEMD_UNIT=vllm-companion@
# COMPANION_REGISTRY_PATH=./data/vllm_models_companion.yaml
COMPANION_DEFAULT_SERVER=            # ollama | vllm | "" — auto-load on startup
COMPANION_DEFAULT_MODEL=             # Ollama tag or vLLM alias (e.g. qwen3:4b or qwen3-4b)

# --- idle auto-unload (power saving) ---
# Reap a lane's model after sustained inactivity so the card drops from P0 (~117 W
# with a model resident on the 3090) to P8 (~25 W). Activity = a /v1 gateway request,
# a load finishing, or GPU utilization above IDLE_UNLOAD_UTIL_PCT (the Monitor signal
# catches clients that hit Ollama / the vLLM relay directly). Reaped models reload
# automatically on the next /v1 request; when no lane serves vLLM the WSL keepalive
# is also released so the distro can idle-shutdown.
IDLE_UNLOAD_ENABLED=true
IDLE_UNLOAD_AFTER_MIN=15             # minutes of no gateway traffic / GPU util
# IDLE_UNLOAD_CHECK_INTERVAL_S=60
# IDLE_UNLOAD_UTIL_PCT=5             # util above this counts as activity

# --- HuggingFace (vLLM model downloads) ---
HF_TOKEN=                            # or rely on WSL's ~/.cache/huggingface/token

# --- paths / tuning ---
# REGISTRY_PATH=./data/vllm_models.yaml
# EVICT_TIMEOUT_S=45
# POLL_INTERVAL_S=2
# DEFAULT_VLLM_LOAD_TIMEOUT_S=240
