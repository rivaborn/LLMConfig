# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/

# Environment / secrets — NEVER commit
.env
.env.bak*
*.local

# Runtime-generated vLLM alias registries (seeded from llmconfig/data/*.default.yaml).
# The user edits these copies; the committed seeds are the defaults.
/data/vllm_models.yaml
/data/vllm_models_companion.yaml
# Runtime-generated per-lane default-model state (set via UI/CLI).
/data/lane_defaults.yaml
# Monitor-tab telemetry history (SQLite + WAL sidecars).
/data/monitor.db*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
